# Logs (keep structure, exclude content)
logs/**/*.json
logs/**/*.md
!logs/**/.gitkeep

# Test artifacts
tests_output.txt
*.trx
TestResults/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Secrets
*.env
*.local.json
repositories.local.json
config/paths.json

# Temp
tmp/
temp/**
!temp/.gitkeep
dumps/
downloaded/
raw-html/
external-cache/
live-cache/

